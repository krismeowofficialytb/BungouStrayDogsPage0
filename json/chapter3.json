      "music": "rain.mp3",
      "next": "c3_s05_dazai"
    },
    "c3_s05_dazai": {
      "id": "c3_s05_dazai",
      "background": "yokohama_night.webp",
      "character": "atsushi_casual.png",
      "speaker": "Atsushi",
      "text": "Qui est Odasaku ?",
      "pause": 400,
      "music": "rain.mp3",
      "next": "c3_s06_dazai"
    },
    "c3_s06_dazai": {
      "id": "c3_s06_dazai",
      "background": "yokohama_night.webp",
      "character": "dazaicasual2.png",
      "speaker": "Dazai",
      "text": "Quelqu'un que j'ai perdu. Et qui m'a appris que vivre avait une valeur. Ce soir, je voulais juste… ne pas être seul sur un toit.",
      "pause": 800,
      "music": "rain.mp3",
      "next": "c3_s07"
    },

    "c3_s04_kunikida": {
      "id": "c3_s04_kunikida",
      "background": "yokohama_night.webp",
      "character": "kunikidaserious.png",
      "speaker": "Kunikida",
      "text": "Je savais que tu serais là. J'ai apporté du thé. Tu as oublié de dîner.",
      "pause": 600,
      "music": "rain.mp3",
      "next": "c3_s05_kunikida"
    },
    "c3_s05_kunikida": {
      "id": "c3_s05_kunikida",
      "background": "yokohama_night.webp",
      "character": "atsushi_casual.png",
      "speaker": "Atsushi",
      "text": "Tu fais ça souvent, noter quand les gens mangent ?",
      "pause": 400,
      "music": "rain.mp3",
      "next": "c3_s06_kunikida"
    },
    "c3_s06_kunikida": {
      "id": "c3_s06_kunikida",
      "background": "yokohama_night.webp",
      "character": "kunikidaglasses.png",
      "speaker": "Kunikida",
      "text": "Seulement pour les membres de l'équipe qui ont tendance à s'effacer quand ça va mal. Bois ton thé.",
      "pause": 700,
      "music": "rain.mp3",
      "next": "c3_s07"
    },

    "c3_s04_ranpo": {
      "id": "c3_s04_ranpo",
      "background": "yokohama_night.webp",
      "character": "ranposerious.png",
      "speaker": "Ranpo",
      "text": "J'avais calculé que tu serais là avec une précision de cent pour cent. La pluie, le toit, exactement l'humeur qu'il te faut.",
      "pause": 600,
      "music": "rain.mp3",
      "next": "c3_s05_ranpo"
    },
    "c3_s05_ranpo": {
      "id": "c3_s05_ranpo",
      "background": "yokohama_night.webp",
      "character": "atsushi_casual.png",
      "speaker": "Atsushi",
      "text": "Tu es… venu exprès ?",
      "pause": 400,
      "music": "rain.mp3",
      "next": "c3_s06_ranpo"
    },
    "c3_s06_ranpo": {
      "id": "c3_s06_ranpo",
      "background": "yokohama_night.webp",
      "character": "ranpoglasses.png",
      "speaker": "Ranpo",
      "text": "Non. J'avais juste envie d'air frais. Le fait que tu sois là est une coïncidence que j'avais prévue.",
      "pause": 700,
      "music": "rain.mp3",
      "next": "c3_s07"
    },

    "c3_s04_lucy": {
      "id": "c3_s04_lucy",
      "background": "yokohama_night.webp",
      "character": "lucysmile.png",
      "speaker": "Lucy",
      "text": "T'es encore là à ruminer ? Pousse-toi. J'apporte du café.",
      "pause": 500,
      "music": "rain.mp3",
      "next": "c3_s05_lucy"
    },
    "c3_s05_lucy": {
      "id": "c3_s05_lucy",
      "background": "yokohama_night.webp",
      "character": "atsushi_casual.png",
      "speaker": "Atsushi",
      "text": "Tu travaillais encore à cette heure ?",
      "pause": 400,
      "music": "rain.mp3",
      "next": "c3_s06_lucy"
    },
    "c3_s06_lucy": {
      "id": "c3_s06_lucy",
      "background": "yokohama_night.webp",
      "character": "lucyspeak.png",
      "speaker": "Lucy",
      "text": "Je dors pas bien quand il pleut. Alors j'ai fait du café. Et je savais que tu avais pas dîné, espèce d'idiot.",
      "pause": 600,
      "music": "rain.mp3",
      "next": "c3_s07"
    },

    "c3_s04_seul": {
      "id": "c3_s04_seul",
      "background": "yokohama_night.webp",
      "character": null,
      "speaker": null,
      "text": "Personne ne monte sur le toit ce soir. La pluie tombe seule, et je l'écoute.",
