      "background": "yokohama_night.webp",
      "character": null,
      "speaker": null,
      "text": "Trois jours ont passé. Yokohama s'endort sous la pluie. Je suis sur le toit de l'Agence.",
      "pause": 700,
      "music": "rain.mp3",
      "next": "c3_s02"
    },

    "c3_s02": {
      "id": "c3_s02",
      "background": "yokohama_night.webp",
      "character": "atsushi_casual.png",
      "speaker": "Atsushi",
      "text": "Je repense au livre. À ce fragment que j'ai perdu. Et à celui qui est venu s'asseoir à côté de moi ce soir.",
      "pause": 600,
      "music": "rain.mp3",
      "next": "c3_s03"
    },

    "c3_s03": {
      "id": "c3_s03",
      "background": "yokohama_night.webp",
      "character": null,
      "speaker": null,
      "text": "Selon l'affinité accumulée, quelqu'un de particulier est monté sur ce toit ce soir...",
      "pause": 500,
      "music": "rain.mp3",
      "affinity_gate": {
        "min_affection": 20,
        "scenes": {
          "Dazai":    "c3_s04_dazai",
